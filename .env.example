# ================================================================
# Automate.sh Content Engine — Environment Configuration
# ================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ================================================================

# ────────────────────────────────────────────────────────────────
# LLM PROVIDER
# Options: ollama | opencode | bigpick | openai
# ────────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama

# API Key (not needed for Ollama)
LLM_API_KEY=not-needed

# Base URL for OpenAI-compatible APIs
# Leave empty for standard OpenAI endpoint
# OpenCode example: https://opencode.ai/api/v1
# BigPick example:  check their documentation
LLM_BASE_URL=

# Model name to use
# Ollama:  llama3.2 | mistral | codellama | gemma2 | qwen2.5-coder
# OpenAI:  gpt-4o-mini | gpt-4o
# OpenCode/BigPick: check available models in their docs
MODEL_NAME=llama3.2

# Ollama server URL (default: local installation)
OLLAMA_BASE_URL=http://localhost:11434

# ────────────────────────────────────────────────────────────────
# DATABASE
# ────────────────────────────────────────────────────────────────
# SQLite (default, no setup required)
DATABASE_URL=sqlite:///./automate_sh.db

# PostgreSQL (future migration)
# DATABASE_URL=postgresql://user:password@localhost:5432/automate_sh

# ────────────────────────────────────────────────────────────────
# QUALITY CONTROL
# ────────────────────────────────────────────────────────────────
# Minimum quality score (1-10) to pass quality gate without retry
QUALITY_THRESHOLD=7

# Maximum pipeline retries if quality check fails
MAX_RETRIES=2

# ────────────────────────────────────────────────────────────────
# COMPOSIO (SOCIAL PUBLISHING)
# ────────────────────────────────────────────────────────────────
COMPOSIO_API_KEY=

# ────────────────────────────────────────────────────────────────
# OUTPUT PATHS
# ────────────────────────────────────────────────────────────────
OUTPUT_DIR=output
CONTENT_DIR=content
